# =============================================================================
# emergency_access_peru — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Raw and processed data  (keep folder structure via .gitkeep files)
# -----------------------------------------------------------------------------
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# -----------------------------------------------------------------------------
# Shapefile binary components  (often large; .dbf can exceed 50 MB)
# Note: git has no size-based ignore rule — all .dbf files are excluded here.
# data/raw/ is already excluded above, so this catches any .dbf placed
# elsewhere in the repo accidentally.
# -----------------------------------------------------------------------------
*.dbf
*.shp
*.shx
*.sbn
*.sbx
*.prj
*.cpg
*.qpj

# -----------------------------------------------------------------------------
# Python bytecode
# -----------------------------------------------------------------------------
__pycache__/
src/__pycache__/
*.py[cod]
*$py.class

# -----------------------------------------------------------------------------
# Python packaging / environments
# -----------------------------------------------------------------------------
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# OS artefacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
